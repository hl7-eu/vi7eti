                  "system": "http://loinc.org",
                  "display": "Hospital discharge procedures Narrative"
                }
              ]
            },
            "title": "Procedures"
          },
          {
            "text": {
              "status": "generated",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">The patient received paracetamol for pain relief and cefazolin as a prophylactic antibiotic post-surgery.<table class=\"hl7__hdr\"><thead><tr><th>Medication administrations</th><th>SNOMED</th></tr></thead><tbody><tr><td>Paracetamol</td><td>387517004</td></tr><tr><td>Cefazolin</td><td>387458008</td></tr></tbody></table></div>"

                  "system": "http://loinc.org",
                  "display": "Hospital discharge procedures Narrative"
                }
              ]
            },
            "title": "Significant procedures"
          },
          {
            "text": {
              "status": "generated",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\">Metformin 500 mg twice daily was started as the first-line treatment to help control blood glucose levels.<table class=\"hl7__hdr\"><thead><tr><th>Medication administrations</th><th>Dose/Frequency</th><th>SNOMED</th></tr></thead><tbody><tr><td>Metformin, oral tbl</td><td>500 mg, twice / day</td><td>765507008</td></tr><tr><td>Multivitamines</td><td>daily</td><td></td></tr></tbody></table></div>"
            },
            "entry": [
              {
                "reference": "urn:uuid:bda0b497-c9f2-47ca-8339-da1d379cb2f4"
              }
            ],
            "code": {

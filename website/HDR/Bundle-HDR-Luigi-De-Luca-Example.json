            "title": "Follow-up"
          },
          {
            "text": {
              "status": "generated",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><table class=\"hl7__hdr\"><thead><tr><th>Discharge Diagnoses</th><th>Codes</th></tr></thead><tbody><tr><td>Type 2 Diabetes Mellitus – Newly diagnosed.</td><td><ul><li>Type 2 diabetes mellitus E11 (ICD-10)</li><li>Diabetes mellitus type 2 (disorder) 44054006 (SNOMED)</li></ul></td></tr></tbody></table></div>"
            },
